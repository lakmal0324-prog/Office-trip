/* INFO BOX */
.info-box { font-size: 12px; color: var(--muted); line-height: 2; }
.warn-box { margin-top: 10px; padding: 8px 12px; background: #f5a62315; border-radius: 10px; font-size: 11px; color: var(--accent); }

.outline-btn {
  width: 100%; padding: 10px; border-radius: 10px;
  font-weight: 700; cursor: pointer; font-size: 13px; font-family: inherit;
  transition: opacity 0.2s;
}
.outline-btn:active { opacity: 0.8; }

/* TX ITEM */
.tx-item {
