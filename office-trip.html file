<style>
* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

:root {
  --bg: #0f1923;
  --card: #1a2634;
  --cardBorder: #243447;
  --accent: #f5a623;
  --accentGlow: #f5a62340;
  --green: #2ecc71;
  --red: #e74c3c;
  --blue: #3498db;
  --text: #e8f4f8;
  --muted: #7f9aad;
  --surface: #141f2b;
}

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Noto Sans Sinhala', 'Segoe UI', sans-serif;
  min-height: 100vh;
  min-height: -webkit-fill-available;
  padding-bottom: 40px;
}

/* LOADING */
#loadingScreen {
  position: fixed; inset: 0;
  background: var(--bg);
  z-index: 999;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 16px;
}
.load-bar-wrap { width: 40px; height: 4px; background: var(--cardBorder); border-radius: 99px; overflow: hidden; margin-top: 8px; }
.load-bar { height: 100%; width: 60%; background: var(--accent); border-radius: 99px; animation: slide 1s infinite; }
@keyframes slide { 0%{transform:translateX(-100%)} 100%{transform:translateX(250%)} }

/* HEADER */
.header {
  background: linear-gradient(135deg, #1a2634 0%, #0f1923 100%);
  border-bottom: 1px solid var(--cardBorder);
  padding: 52px 20px 0;
  position: sticky; top: 0; z-index: 100;
}
.header-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
.header-title { font-size: 22px; font-weight: 800; letter-spacing: -0.5px; }
.header-sync { font-size: 11px; color: var(--muted); margin-top: 2px; }
.header-balance-label { font-size: 11px; color: var(--muted); text-align: right; }
.header-balance { font-size: 20px; font-weight: 800; text-align: right; }

/* TABS */
.tabs { display: flex; gap: 4px; }
.tab {
  flex: 1; padding: 8px 4px; font-size: 11px; font-weight: 700;
  border: none; cursor: pointer; border-radius: 8px 8px 0 0;
  background: transparent; color: var(--muted);
  transition: all .2s; font-family: inherit;
}
.tab.active { background: var(--accent); color: #000; }

/* MAIN */
.main { padding: 20px 16px; max-width: 480px; margin: 0 auto; }

/* NOTIFICATION */
.notif {
  position: fixed; top: 90px; left: 50%; transform: translateX(-50%);
  padding: 10px 20px; border-radius: 30px;
  font-weight: 700; font-size: 13px; z-index: 999;
  box-shadow: 0 4px 20px #0006;
  transition: opacity 0.3s;
  white-space: nowrap;
}

/* CARDS */
.card {
  background: var(--card);
  border: 1px solid var(--cardBorder);
  border-radius: 16px; padding: 16px;
}
.card-title { font-size: 15px; font-weight: 800; margin-bottom: 16px; }

/* STATS GRID */
.stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px; }
.stat-card { background: var(--card); border: 1px solid var(--cardBorder); border-radius: 16px; padding: 16px; }
.stat-icon { font-size: 22px; }
.stat-label { font-size: 11px; color: var(--muted); margin-top: 6px; }
.stat-value { font-size: 18px; font-weight: 800; margin-top: 4px; }

/* BALANCE CARD */
.balance-card {
  border-radius: 16px; padding: 20px; text-align: center; margin-bottom: 16px;
}
.balance-card .label { font-size: 13px; color: var(--muted); }
.balance-card .amount { font-size: 36px; font-weight: 900; margin-top: 6px; }
.balance-card .sub { font-size: 12px; color: var(--muted); margin-top: 4px; }

/* CATEGORY BAR */
.cat-row { margin-bottom: 10px; }
.cat-row-top { display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 4px; }
.bar-bg { height: 6px; background: var(--surface); border-radius: 99px; overflow: hidden; }
.bar-fill { height: 100%; background: linear-gradient(90deg, var(--accent), #ff6b35); border-radius: 99px; transition: width .5s; }

/* PERSON ROW */
.person-row {
  display: flex; align-items: center; gap: 12px;
  padding: 8px 0; border-bottom: 1px solid var(--cardBorder);
}
.avatar {
  width: 32px; height: 32px; border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), #ff6b35);
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; font-weight: 700; color: #000; flex-shrink: 0;
}
.avatar.large { width: 38px; height: 38px; font-size: 16px; }

/* FORM */
.form-group { margin-bottom: 14px; }
.form-label { font-size: 12px; color: var(--muted); display: block; margin-bottom: 6px; }
.input {
  width: 100%; background: var(--surface);
  border: 1px solid var(--cardBorder); border-radius: 10px;
  padding: 12px 14px; color: var(--text); font-size: 15px;
  outline: none; font-family: inherit;
  transition: border-color 0.2s;
}
.input:focus { border-color: var(--accent); }
.input::placeholder { color: var(--muted); }

/* TYPE TOGGLE */
.type-toggle { display: flex; gap: 8px; margin-bottom: 16px; background: var(--surface); border-radius: 12px; padding: 4px; }
.type-btn {
  flex: 1; padding: 10px; border: none; border-radius: 10px; cursor: pointer;
