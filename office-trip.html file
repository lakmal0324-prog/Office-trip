/* ADD MEMBER ROW */
.add-member-row { display: flex; gap: 10px; }
.add-member-row .input { flex: 1; }
.icon-btn {
  padding: 10px 16px; border-radius: 10px; border: none;
  cursor: pointer; font-weight: 800; font-size: 14px; font-family: inherit;
}

/* DASHED BTN */
.dashed-btn {
  width: 100%; padding: 12px; border-radius: 12px;
  border: 2px dashed var(--cardBorder); background: transparent;
  color: var(--muted); cursor: pointer; font-size: 13px; font-weight: 600;
