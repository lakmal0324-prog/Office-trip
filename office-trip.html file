}
.type-btn.income.active { background: var(--green); color: #fff; }
.type-btn.expense.active { background: var(--red); color: #fff; }

/* CHIP BUTTONS */
.chips { display: flex; flex-wrap: wrap; gap: 8px; }
.chip {
