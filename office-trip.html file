<script>
// ─── CONFIG ───────────────────────────────────────────────
const STORAGE_KEY = 'office-trip-data-v2';
const POLL_MS = 4000;

const CATEGORIES = ['ආහාර','ගමන','නවාතැන','කඩ','විනෝදාංශ','වෙනත්'];
const CAT_EMOJI = {'ආහාර':'🍽️','ගමන':'🚌','නවාතැන':'🏨','කඩ':'🛍️','විනෝදාංශ':'🎡','වෙනත්':'📦'};

// ─── STATE ────────────────────────────────────────────────
let members = [];
let transactions = [];
let currentType = 'income';
let currentCat = 'ආහාර';
let currentPaidBy = '';
let pollTimer = null;
let lastSavedTs = 0;

// ─── STORAGE (localStorage with shared-sim) ───────────────
function loadData(isPolling = false) {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (raw) {
      const data = JSON.parse(raw);
      if (!isPolling || data.updatedAt > lastSavedTs) {
        members = data.members || [];
        transactions = data.transactions || [];
      }
    }
    setSyncStatus('ok');
    renderAll();
  } catch(e) {
    setSyncStatus('error');
  }
}

function saveData() {
  const ts = Date.now();
  lastSavedTs = ts;
  const payload = { members, transactions, updatedAt: ts };
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(payload));
    setSyncStatus('ok');
  } catch(e) {
    setSyncStatus('error');
    showNotif('⚠️ Save failed', '#e74c3c');
  }
}

// ─── SYNC STATUS ──────────────────────────────────────────
function setSyncStatus(status) {
  const el = document.getElementById('syncStatus');
  const now = new Date().toLocaleTimeString('si-LK');
  if (status === 'ok') el.innerHTML = `⟳ ${now} · <span style="color:var(--green)">● LIVE</span>`;
  if (status === 'error') el.innerHTML = `<span style="color:var(--red)">⚠️ Sync error</span>`;
  if (status === 'loading') el.innerHTML = `<span style="color:var(--accent)">⏳ Loading…</span>`;
}

// ─── NOTIFICATION ─────────────────────────────────────────
let notifTimer = null;
function showNotif(msg, color = '#2ecc71') {
  const el = document.getElementById('notif');
  el.textContent = msg;
  el.style.background = color;
  el.style.color = '#fff';
  el.style.display = 'block';
  el.style.opacity = '1';
  clearTimeout(notifTimer);
  notifTimer = setTimeout(() => { el.style.opacity = '0'; setTimeout(()=>el.style.display='none', 300); }, 2800);
}

// ─── TABS ─────────────────────────────────────────────────
function switchTab(id, btn) {
  document.querySelectorAll('[id^="tab-"]').forEach(el => el.style.display = 'none');
  document.getElementById('tab-' + id).style.display = 'block';
  document.querySelectorAll('.tab').forEach(el => el.classList.remove('active'));
  btn.classList.add('active');
}

// ─── MEMBERS ──────────────────────────────────────────────
function showAddMember() {
  document.getElementById('addMemberArea').style.display = 'none';
  document.getElementById('addMemberForm').style.display = 'block';
  document.getElementById('newMemberInput').focus();
}
function hideAddMember() {
  document.getElementById('addMemberArea').style.display = 'block';
  document.getElementById('addMemberForm').style.display = 'none';
  document.getElementById('newMemberInput').value = '';
}
function addMember() {
  const input = document.getElementById('newMemberInput');
  const name = input.value.trim();
  if (!name) return;
  if (members.includes(name)) { showNotif('නමක් දැනටමත් ඇත!', '#e74c3c'); return; }
  members.push(name);
  saveData();
  input.value = '';
  hideAddMember();
  renderAll();
  showNotif(`${name} එකතු කරන ලදී ✓`);
}
function renderMembers() {
  const spend = getMemberSpend();
  const list = document.getElementById('memberList');
  if (members.length === 0) {
    list.innerHTML = '<div style="text-align:center;color:var(--muted);padding:20px 0;font-size:13px">තවම members නැත. Add කරන්න!</div>';
    return;
  }
  list.innerHTML = members.map(m => `
    <div class="member-item">
      <div class="avatar large">${m[0].toUpperCase()}</div>
      <div style="flex:1">
        <div style="font-weight:700;font-size:14px">${m}</div>
        <div style="font-size:11px;color:var(--muted)">වියදම: ${fmt(spend[m]||0)}</div>
      </div>
    </div>
  `).join('');
}

// ─── FORM ─────────────────────────────────────────────────
function setType(type) {
  currentType = type;
  document.getElementById('typeIncome').className = 'type-btn income' + (type==='income'?' active':'');
  document.getElementById('typeExpense').className = 'type-btn expense' + (type==='expense'?' active':'');
  document.getElementById('paidByGroup').style.display = type==='expense' ? 'block' : 'none';
  document.getElementById('submitBtn').textContent = type==='income' ? '💰 ආදායම් එකතු කරන්න' : '💸 වියදම් එකතු කරන්න';
}

function renderCatChips() {
  document.getElementById('catChips').innerHTML = CATEGORIES.map(c => `
    <button class="chip ${c===currentCat?'cat-active':''}" onclick="setCat('${c}')">${CAT_EMOJI[c]} ${c}</button>
  `).join('');
}
function setCat(cat) { currentCat = cat; renderCatChips(); }

function renderPaidByChips() {
  const el = document.getElementById('paidByChips');
  if (members.length === 0) {
    el.innerHTML = '<span style="font-size:12px;color:var(--muted)">Members tab එකෙන් කෙනෙකු එකතු කරන්න</span>';
    return;
  }
  el.innerHTML = members.map(m => `
    <button class="chip ${m===currentPaidBy?'paid-active':''}" onclick="setPaidBy('${m}')">${m}</button>
  `).join('');
}
function setPaidBy(m) { currentPaidBy = m; renderPaidByChips(); }

function addTransaction() {
  const amount = parseFloat(document.getElementById('fAmount').value);
  const desc = document.getElementById('fDesc').value.trim();
  if (!amount || amount <= 0) { showNotif('වලංගු මුදලක් ඇතුලු කරන්න', '#e74c3c'); return; }
  if (!desc) { showNotif('විස්තරය ඇතුලු කරන්න', '#e74c3c'); return; }
  if (currentType === 'expense' && !currentPaidBy) { showNotif('ගෙවන්නා තෝරන්න', '#e74c3c'); return; }

  const tx = {
    id: Date.now(),
    type: currentType,
    amount,
    desc,
    category: currentCat,
    paidBy: currentType === 'expense' ? currentPaidBy : null,
    date: new Date().toLocaleString('si-LK'),
    ts: Date.now()
  };
  transactions.unshift(tx);
  saveData();
  document.getElementById('fAmount').value = '';
  document.getElementById('fDesc').value = '';
  renderAll();
  showNotif(currentType === 'income' ? 'ආදායම් එකතු කරන ලදී ✓' : 'වියදම් එකතු කරන ලදී ✓');
}

function deleteTransaction(id) {
  transactions = transactions.filter(t => t.id !== id);
  saveData();
  renderAll();
  showNotif('ගනුදෙනුව ඉවත් කරන ලදී');
}

// ─── CALCULATIONS ─────────────────────────────────────────
function getMemberSpend() {
  return members.reduce((acc, m) => {
    acc[m] = transactions.filter(t => t.type==='expense' && t.paidBy===m).reduce((s,t)=>s+t.amount,0);
    return acc;
  }, {});
}

function fmt(n) { return 'රු. ' + Number(n).toLocaleString('si-LK'); }

// ─── RENDER ───────────────────────────────────────────────
function renderDashboard() {
  const totalIn = transactions.filter(t=>t.type==='income').reduce((s,t)=>s+t.amount,0);
  const totalEx = transactions.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0);
  const balance = totalIn - totalEx;

  document.getElementById('totalIncome').textContent = fmt(totalIn);
  document.getElementById('totalExpense').textContent = fmt(totalEx);
  document.getElementById('headerBalance').textContent = fmt(balance);
  document.getElementById('headerBalance').style.color = balance >= 0 ? 'var(--green)' : 'var(--red)';
  document.getElementById('balanceAmount').textContent = fmt(Math.abs(balance));
  document.getElementById('balanceAmount').style.color = balance >= 0 ? 'var(--green)' : 'var(--red)';
  document.getElementById('balanceSub').textContent = balance >= 0 ? 'ඉතිරි ශේෂය ✅' : 'ශේෂය නැත ⚠️';

  const bc = document.getElementById('balanceCard');
  bc.style.background = balance >= 0
    ? 'linear-gradient(135deg, #1a3a2a, var(--card))'
    : 'linear-gradient(135deg, #3a1a1a, var(--card))';
  bc.style.border = `1px solid ${balance >= 0 ? '#2ecc7150' : '#e74c3c50'}`;

  // Categories
  const catTotals = CATEGORIES.map(c => ({
    cat: c,
    total: transactions.filter(t=>t.type==='expense'&&t.category===c).reduce((s,t)=>s+t.amount,0)
  })).filter(c=>c.total>0).sort((a,b)=>b.total-a.total);

  const catCard = document.getElementById('catCard');
  if (catTotals.length > 0) {
    catCard.style.display = 'block';
    document.getElementById('catList').innerHTML = catTotals.map(({cat,total}) => `
      <div class="cat-row">
        <div class="cat-row-top">
          <span>${CAT_EMOJI[cat]} ${cat}</span>
          <span style="color:var(--accent);font-weight:700">${fmt(total)}</span>
        </div>
        <div class="bar-bg"><div class="bar-fill" style="width:${Math.min(100,(total/totalEx)*100)}%"></div></div>
      </div>
    `).join('');
  } else { catCard.style.display = 'none'; }

  // Member spend
  const spend = getMemberSpend();
  const mCard = document.getElementById('memberSpendCard');
  if (members.length > 0) {
    mCard.style.display = 'block';
    document.getElementById('memberSpendList').innerHTML = members.map(m => `
      <div class="person-row">
        <div style="display:flex;align-items:center;gap:10px;flex:1">
          <div class="avatar">${m[0]}</div>
          <span style="font-size:14px">${m}</span>
        </div>
        <span style="font-weight:700;color:${(spend[m]||0)>0?'var(--red)':'var(--muted)'};font-size:14px">${fmt(spend[m]||0)}</span>
      </div>
    `).join('');
  } else { mCard.style.display = 'none'; }
}

function renderHistory() {
  document.getElementById('historyTitle').textContent = `📋 ගනුදෙනු ඉතිහාසය (${transactions.length})`;
  const list = document.getElementById('txList');
  if (transactions.length === 0) {
    list.innerHTML = '<div class="empty">😴 ගනුදෙනු නැත. Add tab එකෙන් add කරන්න!</div>';
    return;
  }
  list.innerHTML = transactions.map(tx => `
    <div class="tx-item ${tx.type}">
      <div class="tx-icon">${tx.type==='income'?'💰':CAT_EMOJI[tx.category]}</div>
      <div class="tx-body">
        <div class="tx-desc">${tx.desc}</div>
        <div class="tx-meta">${tx.type==='expense'?`${tx.paidBy} · ${tx.category}`:'ආදායම'} · ${tx.date}</div>
      </div>
      <div style="text-align:right">
        <div class="tx-amount" style="color:${tx.type==='income'?'var(--green)':'var(--red)'}">
          ${tx.type==='income'?'+':'-'}${fmt(tx.amount)}
        </div>
        <button class="tx-delete" onclick="deleteTransaction(${tx.id})">🗑️ Delete</button>
      </div>
    </div>
  `).join('');
}

function renderAll() {
  renderDashboard();
  renderMembers();
  renderCatChips();
  renderPaidByChips();
  renderHistory();
}

// ─── UTILS ────────────────────────────────────────────────
function copyLink() {
  const url = window.location.href;
  if (navigator.clipboard) {
    navigator.clipboard.writeText(url).then(() => showNotif('Link copied! 🔗 WhatsApp share කරන්න'));
  } else {
    showNotif('URL: ' + url);
  }
}

function resetData() {
  if (!confirm('සියලු data delete කරන්නද? Trip ඉවර වූ පසු මෙය use කරන්න.')) return;
  localStorage.removeItem(STORAGE_KEY);
  members = []; transactions = []; lastSavedTs = 0;
  renderAll();
  showNotif('Data reset කරන ලදී', '#f5a623');
}

// ─── INIT ─────────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  // Hide loading after brief delay
  setTimeout(() => {
    document.getElementById('loadingScreen').style.display = 'none';
  }, 800);

  setType('income');
  loadData(false);

  // Poll every 4s
  pollTimer = setInterval(() => loadData(true), POLL_MS);
});
</script>

</body>
</html>
