  cursor: pointer; font-weight: 600; transition: all .2s; font-family: inherit;
  border: 1px solid var(--cardBorder); background: transparent; color: var(--muted);
}
.chip.cat-active { border-color: var(--accent); background: var(--accentGlow); color: var(--accent); }
.chip.paid-active { border-color: var(--blue); background: #3498db30; color: var(--blue); }

/* SUBMIT BTN */
.submit-btn {
